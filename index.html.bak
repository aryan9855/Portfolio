<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alex Mercer — Creative Developer & Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5F0E8;
    --warm-white: #FAFAF7;
    --black: #0A0A0A;
    --charcoal: #1A1A1A;
    --accent: #C8A96E;
    --accent-light: #E8D5A3;
    --muted: #8A8A80;
    --border: rgba(10,10,10,0.1);
    --red: #D4442A;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--warm-white);
    color: var(--black);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
    cursor: none;
  }

  /* CUSTOM CURSOR */
  .cursor {
    width: 12px; height: 12px;
    background: var(--black);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.15s ease, background 0.2s ease;
    transform: translate(-50%, -50%);
  }
  .cursor-follower {
    width: 36px; height: 36px;
    border: 1.5px solid var(--black);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 9998;
    transition: transform 0.35s ease, opacity 0.2s ease;
    transform: translate(-50%, -50%);
    opacity: 0.5;
  }
  body:hover .cursor { opacity: 1; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 24px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    mix-blend-mode: normal;
    background: rgba(250,250,247,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: padding 0.3s ease;
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-style: italic;
    color: var(--black);
    text-decoration: none;
    letter-spacing: -0.5px;
  }
  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--black);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }
  .nav-cta {
    background: var(--black);
    color: var(--cream) !important;
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 13px !important;
    font-weight: 600 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s !important;
  }
  .nav-cta:hover { background: var(--accent) !important; color: var(--black) !important; transform: translateY(-1px); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
    padding-top: 80px;
  }
  .hero-left {
    background: var(--cream);
    padding: 80px 60px 80px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .hero-right {
    background: linear-gradient(135deg, #E8D5A3 0%, #C8A96E 40%, #A07840 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .hero-right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 70%, rgba(255,255,255,0.25) 0%, transparent 60%);
  }
  .hero-blob {
    position: absolute;
    bottom: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 340px;
    height: 440px;
    background: var(--cream);
    border-radius: 200px 200px 0 0;
    opacity: 0.15;
  }
  .hero-portrait-wrap {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .hero-portrait-placeholder {
    width: 320px;
    height: 420px;
    background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.08) 100%);
    border-radius: 180px 180px 0 0;
    border: 1px solid rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
    color: rgba(255,255,255,0.8);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 0;
  }
  .portrait-icon {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
  }
  .available-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 32px;
    width: fit-content;
    box-shadow: 0 2px 20px rgba(0,0,0,0.08);
  }
  .badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #4CAF50;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(76,175,80,0.4); }
    50% { box-shadow: 0 0 0 6px rgba(76,175,80,0); }
  }
  .hero-greeting {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(52px, 7vw, 90px);
    line-height: 0.95;
    color: var(--black);
    margin-bottom: 16px;
    letter-spacing: -2px;
  }
  .hero-name {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(54px, 7.5vw, 96px);
    font-weight: 700;
    line-height: 0.88;
    color: var(--black);
    letter-spacing: -4px;
    margin-bottom: 24px;
    text-transform: uppercase;
  }
  .hero-title {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(14px, 2vw, 18px);
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  .hero-desc {
    font-size: 15px;
    color: var(--charcoal);
    max-width: 340px;
    line-height: 1.7;
    margin-bottom: 40px;
    opacity: 0.75;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .btn-primary {
    background: var(--black);
    color: var(--cream);
    padding: 14px 32px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.25s;
  }
  .btn-primary:hover { background: var(--accent); color: var(--black); transform: translateY(-2px); }
  .btn-secondary {
    color: var(--black);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--black);
    padding-bottom: 2px;
    transition: all 0.2s;
  }
  .btn-secondary:hover { color: var(--accent); border-color: var(--accent); }
  .hero-stats {
    position: absolute;
    bottom: 40px;
    right: 40px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 3;
  }
  .stat {
    text-align: right;
  }
  .stat-num {
    font-family: 'Space Mono', monospace;
    font-size: 36px;
    font-weight: 700;
    color: white;
    line-height: 1;
  }
  .stat-label {
    font-size: 11px;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* MARQUEE */
  .marquee-strip {
    background: var(--black);
    padding: 16px 0;
    overflow: hidden;
    display: flex;
    white-space: nowrap;
  }
  .marquee-track {
    display: inline-flex;
    animation: marquee 20s linear infinite;
    gap: 0;
  }
  .marquee-item {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 18px;
    color: var(--cream);
    padding: 0 40px;
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .marquee-item::after {
    content: '★';
    color: var(--accent);
    font-size: 12px;
    font-style: normal;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* SECTION STYLES */
  section { padding: 100px 60px; }
  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--accent);
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -2px;
    color: var(--black);
    margin-bottom: 16px;
  }

  /* SERVICES */
  #services {
    background: var(--cream);
    padding: 100px 60px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 60px;
    background: var(--border);
  }
  .service-card {
    background: var(--cream);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s, transform 0.3s;
  }
  .service-card:hover { background: var(--black); }
  .service-card:hover .service-num,
  .service-card:hover .service-name,
  .service-card:hover .service-desc { color: var(--cream); }
  .service-card:hover .service-icon { background: var(--accent); }
  .service-num {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-bottom: 40px;
    transition: color 0.3s;
  }
  .service-icon {
    width: 48px; height: 48px;
    background: var(--black);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 24px;
    transition: background 0.3s;
  }
  .service-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 12px;
    transition: color 0.3s;
  }
  .service-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    transition: color 0.3s;
  }

  /* WORKS */
  #works { padding: 100px 60px; }
  .works-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
  }
  .project-card {
    position: relative;
    overflow: hidden;
    background: var(--cream);
    aspect-ratio: 4/3;
    cursor: none;
  }
  .project-card:first-child { grid-row: span 2; aspect-ratio: auto; }
  .project-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .project-bg {
    width: 100%;
    height: 100%;
    transition: transform 0.6s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 72px;
    position: relative;
  }
  .project-card:nth-child(1) .project-bg { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }
  .project-card:nth-child(2) .project-bg { background: linear-gradient(135deg, #2d1b69 0%, #6b35a6 100%); }
  .project-card:nth-child(3) .project-bg { background: linear-gradient(135deg, #1a472a 0%, #2d6a4f 100%); }
  .project-card:nth-child(4) .project-bg { background: linear-gradient(135deg, #7f1d1d 0%, #c0392b 100%); }
  .project-card:hover .project-bg { transform: scale(1.05); }
  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 50%);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .project-card:hover .project-overlay { opacity: 1; }
  .project-info-always {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
  }
  .project-tag {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .project-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: white;
    line-height: 1.2;
  }
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: white;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.4);
    padding-bottom: 2px;
    margin-top: 12px;
    transition: border-color 0.2s;
  }
  .project-link:hover { border-color: var(--accent); color: var(--accent); }

  /* ABOUT */
  #about {
    background: var(--black);
    color: var(--cream);
    padding: 100px 60px;
  }
  #about .section-title { color: var(--cream); }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-top: 60px;
    align-items: start;
  }
  .about-text p {
    font-size: 16px;
    line-height: 1.8;
    color: rgba(245,240,232,0.75);
    margin-bottom: 20px;
  }
  .about-facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 40px;
  }
  .fact {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: 20px;
  }
  .fact-num {
    font-family: 'Space Mono', monospace;
    font-size: 40px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 6px;
  }
  .fact-label {
    font-size: 13px;
    color: rgba(245,240,232,0.5);
    letter-spacing: 0.05em;
  }
  .skills-section h3 {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--cream);
    margin-bottom: 32px;
  }
  .skill-row {
    margin-bottom: 24px;
  }
  .skill-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 13px;
    color: rgba(245,240,232,0.6);
  }
  .skill-bar-bg {
    height: 3px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    overflow: hidden;
  }
  .skill-bar {
    height: 100%;
    background: linear-gradient(to right, var(--accent), #E8D5A3);
    border-radius: 2px;
    transition: width 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 32px;
  }
  .tool-tag {
    padding: 6px 14px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    font-size: 12px;
    color: rgba(245,240,232,0.65);
    font-family: 'Space Mono', monospace;
    transition: all 0.2s;
  }
  .tool-tag:hover { border-color: var(--accent); color: var(--accent); }

  /* EXPERIENCE */
  #experience {
    padding: 100px 60px;
    background: var(--warm-white);
  }
  .experience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-top: 60px;
  }
  .timeline-list { display: flex; flex-direction: column; }
  .timeline-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 24px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-year {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    padding-top: 4px;
  }
  .timeline-role {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .timeline-company {
    font-size: 14px;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .timeline-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
  }

  /* TESTIMONIALS */
  #testimonials {
    background: var(--cream);
    padding: 100px 60px;
    overflow: hidden;
  }
  .testimonials-row {
    display: flex;
    gap: 24px;
    margin-top: 60px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 8px;
  }
  .testimonials-row::-webkit-scrollbar { display: none; }
  .testimonial-card {
    background: white;
    padding: 40px;
    border-radius: 20px;
    min-width: 360px;
    flex-shrink: 0;
    box-shadow: 0 4px 40px rgba(0,0,0,0.06);
    transition: transform 0.3s;
  }
  .testimonial-card:hover { transform: translateY(-6px); }
  .quote-mark {
    font-family: 'Playfair Display', serif;
    font-size: 60px;
    line-height: 0.8;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .testimonial-text {
    font-size: 15px;
    line-height: 1.75;
    color: var(--charcoal);
    margin-bottom: 28px;
    font-style: italic;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .author-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    font-weight: 700;
    background: var(--cream);
    color: var(--black);
    font-family: 'Playfair Display', serif;
    border: 2px solid var(--border);
  }
  .author-name {
    font-weight: 600;
    font-size: 14px;
  }
  .author-role {
    font-size: 12px;
    color: var(--muted);
  }
  .stars { color: var(--accent); font-size: 14px; margin-bottom: 16px; }

  /* CONTACT */
  #contact {
    background: var(--black);
    padding: 120px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  #contact::before {
    content: 'LET\'S\ATALK';
    white-space: pre;
    font-family: 'Playfair Display', serif;
    font-size: clamp(100px, 18vw, 260px);
    font-weight: 900;
    color: rgba(255,255,255,0.03);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    line-height: 0.85;
    letter-spacing: -10px;
  }
  .contact-inner { position: relative; z-index: 2; }
  #contact .section-label { justify-content: center; }
  #contact .section-label::before { display: none; }
  .contact-big {
    font-family: 'Playfair Display', serif;
    font-size: clamp(48px, 8vw, 120px);
    font-weight: 900;
    color: var(--cream);
    line-height: 0.9;
    letter-spacing: -4px;
    margin: 20px 0 40px;
  }
  .contact-big em {
    color: var(--accent);
    font-style: italic;
  }
  .contact-email {
    font-family: 'Space Mono', monospace;
    font-size: clamp(16px, 2.5vw, 28px);
    color: rgba(245,240,232,0.5);
    text-decoration: none;
    border-bottom: 1px solid rgba(245,240,232,0.2);
    padding-bottom: 4px;
    transition: all 0.3s;
    display: inline-block;
    margin-bottom: 48px;
  }
  .contact-email:hover { color: var(--accent); border-color: var(--accent); }
  .contact-socials {
    display: flex;
    justify-content: center;
    gap: 16px;
  }
  .social-btn {
    width: 48px; height: 48px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(245,240,232,0.6);
    text-decoration: none;
    font-size: 18px;
    transition: all 0.25s;
  }
  .social-btn:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); background: rgba(200,169,110,0.1); }

  /* FOOTER */
  footer {
    background: var(--charcoal);
    padding: 32px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  footer span {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
  }
  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 20px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
  }

  /* SCROLL ANIMATIONS */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  @media (max-width: 900px) {
    nav { padding: 20px 24px; }
    .nav-links { display: none; }
    section { padding: 60px 24px; }
    .hero { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .hero-left { padding: 40px 24px; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .projects-grid { grid-template-columns: 1fr; }
    .project-card:first-child { grid-row: span 1; aspect-ratio: 4/3; }
    .about-grid, .experience-grid { grid-template-columns: 1fr; gap: 40px; }
    footer { flex-direction: column; gap: 12px; text-align: center; }
    #services, #works, #about, #experience, #testimonials, #contact { padding: 60px 24px; }
  }
</style>
</head>
