{
  "name": "myportfolio",
  "version": "1.0.0",
  "description": "Premium React Portfolio with Gmail Contact Backend",
  "scripts": {
    "start": "npm run start --prefix backend",
    "postinstall": "npm install --prefix backend --omit=dev",
    "server": "npm run start --prefix backend",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
